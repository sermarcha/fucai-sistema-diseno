# Normalización de fin de línea
* text=auto eol=lf

# === Git LFS — activos binarios pesados ===
# Imágenes
*.png  filter=lfs diff=lfs merge=lfs -text
*.jpg  filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text

# Tipografías
*.otf   filter=lfs diff=lfs merge=lfs -text
*.ttf   filter=lfs diff=lfs merge=lfs -text
*.woff2 filter=lfs diff=lfs merge=lfs -text

# === Plantillas maestras (.docx .xlsx .pptx) ===
# En el repo, los binarios de Office son siempre plantillas/fuentes (incluida la
# copia del skill en skill/fucai-branding/assets/templates/). Se rastrean por LFS
# en cualquier ubicación.
*.docx filter=lfs diff=lfs merge=lfs -text
*.xlsx filter=lfs diff=lfs merge=lfs -text
*.pptx filter=lfs diff=lfs merge=lfs -text
